                                    },
                                    {
                                        "kind": "builtin",
                                        "value": "nil"
                                    }
                                ]
                            }
                        }
                    ]
                }
            },
            {
                "name": "trust",
                "documentation": [
                    "```lua",
                    "function M.trust(opts: vim.trust.opts)",
                    "  -\u003e success: boolean",
