                    "```",
                    "",
                    "---",
                    "",
                    "",
                    " Undo sequence number.  Same as what appears in",
                    " \\|:undolist|."
                ],
                "meta": [
                    "static"
                ],
                "type": {
                    "kind": "builtin",
                    "value": "integer"
                }
            },
