                "documentation": [
                    "```lua",
                    "(field) lsp.ClientCompletionItemOptions.insertReplaceSupport: boolean?",
                    "```",
                    "",
                    "---",
                    "",
                    "",
                    "Client support insert replace edit to control different behavior if a",
                    "completion item is inserted in the text or should replace text.",
                    ""
                ],
                "meta": [],
                "type": {
                    "kind": "optional",
                    "type": {
                        "kind": "builtin",
                        "value": "boolean"
                    }
                }
            },
            {
                "name": "insertTextModeSupport",
                "documentation": [
                    "```lua",
                    "(field) lsp.ClientCompletionItemOptions.insertTextModeSupport: (lsp.ClientCompletionItemInsertTextModeOptions)?",
                    "```",
                    "",
                    "---",
                    "",
                    "",
                    "The client supports the `insertTextMode` property on",
                    "a completion item to override the whitespace handling mode",
                    "as defined by the client (see `insertTextMode`).",
                    ""
                ],
                "meta": [],
                "type": {
                    "kind": "optional",
                    "type": {
                        "kind": "typereference",
                        "value": "lsp.ClientCompletionItemInsertTextModeOptions"
                    }
                }
            },
            {
                "name": "labelDetailsSupport",
                "documentation": [
