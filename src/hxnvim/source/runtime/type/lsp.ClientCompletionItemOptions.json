                ],
                "meta": [],
                "type": {
                    "kind": "optional",
                    "type": {
                        "kind": "builtin",
                        "value": "boolean"
                    }
                }
            },
            {
                "name": "preselectSupport",
                "documentation": [
                    "```lua",
                    "(field) lsp.ClientCompletionItemOptions.preselectSupport: boolean?",
