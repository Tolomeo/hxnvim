                                "value": "integer"
                            }
                        },
                        {
                            "documentation": [],
                            "name": "opts",
                            "optional": true,
                            "type": {
                                "kind": "typereference",
                                "value": "vim.lsp.completion.BufferOpts"
                            }
                        }
                    ],
                    "generics": [],
