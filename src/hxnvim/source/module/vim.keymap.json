                "name": "del",
                "documentation": [
                    "```lua",
                    "function keymap.del(modes: string|string[], lhs: string, opts?: vim.keymap.del.Opts)",
                    "```",
                    "",
                    "---",
                    "",
                    " Remove an existing mapping.",
                    " Examples:",
                    "",
                    " ```lua",
                    " vim.keymap.del('n', 'lhs')",
                    "",
                    " vim.keymap.del({'n', 'i', 'v'}, '\u003cleader\u003ew', { buffer = 5 })",
                    " ```"
                ],
