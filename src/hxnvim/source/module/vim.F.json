                "name": "if_nil",
                "documentation": [
                    "```lua",
                    "function F.if_nil(...\u003cT\u003e)",
                    "  -\u003e \u003cT\u003e",
                    "```",
                    "",
                    "---",
                    "",
                    " Returns the first argument which is not nil.",
                    "",
                    " If all arguments are nil, returns nil.",
                    "",
                    " Examples:",
                    "",
                    " ```lua",
                    " local a = nil",
                    " local b = nil",
                    " local c = 42",
                    " local d = true",
                    " assert(vim.F.if_nil(a, b, c, d) == 42)",
                    " ```"
                ],
