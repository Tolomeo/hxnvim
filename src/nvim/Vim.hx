		return #1:
		    | 'file'
		    | 'dir'
		    | 'link'
		    | 'bdev'
		    | 'cdev'
		    | 'socket'
		    | 'fifo'
		    | 'other'
		```
	**/
	static function getftype(fname:String):String;
